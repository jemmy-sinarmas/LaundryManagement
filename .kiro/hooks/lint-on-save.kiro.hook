{
  "enabled": true,
  "name": "Lint on Save",
  "description": "Runs ESLint across both apps whenever a TypeScript or TSX file is saved",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "apps/**/*.ts",
      "apps/**/*.tsx",
      "packages/**/*.ts"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "pnpm --filter @laundry-palu/web run lint",
    "timeout": 60
  }
}