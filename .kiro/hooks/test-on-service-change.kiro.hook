{
  "enabled": true,
  "name": "Test on Service/Repo Change",
  "description": "Runs the Vitest test suite whenever a service or repository file is saved — these are the highest-risk business logic files",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "apps/api/src/**/*.service.ts",
      "apps/api/src/**/*.repo.ts"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "pnpm --filter @laundry-palu/api run test",
    "timeout": 120
  }
}