{
  "enabled": true,
  "name": "Typecheck on Save",
  "description": "Runs tsc --noEmit on both apps whenever a TypeScript file is saved",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "apps/**/*.ts",
      "apps/**/*.tsx",
      "packages/**/*.ts"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "pnpm run typecheck",
    "timeout": 60
  }
}