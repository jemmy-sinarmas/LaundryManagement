# Copy this file to .env.prod and fill in real values.
# .env.prod is gitignored — never commit it.

# GitHub Container Registry owner (your GitHub username or org name)
GHCR_OWNER=your-github-username

# Image tag — use "latest" or a specific "sha-<commit>" to pin a release
IMAGE_TAG=latest

# Postgres
POSTGRES_DB=laundry_palu
POSTGRES_USER=laundry
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# API runtime
DATABASE_URL=postgres://laundry:CHANGE_ME_STRONG_PASSWORD@postgres:5432/laundry_palu
JWT_SECRET=CHANGE_ME_32_CHARS_MINIMUM_RANDOM_STRING
JWT_EXPIRES_IN=8h

# Must exactly match the origin the browser uses to reach the web app
# (protocol + host + port, e.g. http://123.45.67.89:3000)
CORS_ORIGIN=http://YOUR_SERVER_IP:3000
