# Copy to .env and fill in real values:  cp .env.deploy.example .env
# Used by docker-compose.deploy.yml (build-on-server + Caddy HTTPS). See docs/DEPLOYMENT.md.

# --- Public hostname (DNS A record must point at this server) ---
DOMAIN=laundry.example.com
# Email Let's Encrypt uses for cert expiry notices.
ACME_EMAIL=you@example.com

# --- Database (EXTERNAL PostgreSQL running on the Docker host) ---
# Host is 'host.docker.internal' (the Docker host), NOT 'localhost' — inside a
# container 'localhost' is the container itself. The api service maps
# host.docker.internal to the host gateway (see docker-compose.deploy.yml).
#
# Percent-encode any reserved characters in the password: '@' -> %40, ':' -> %3A.
# Example: the password Admin@123 becomes Admin%40123 below.
# The 'laundry_palu' database must already exist on the host (CREATE DATABASE laundry_palu;).
DATABASE_URL=postgresql://postgres:Admin%40123@host.docker.internal:5432/laundry_palu

# --- Auth (MUST be >= 32 chars; the API and web share this one secret) ---
# Generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARACTERS_LONG_RANDOM_STRING
JWT_EXPIRES_IN=8h
